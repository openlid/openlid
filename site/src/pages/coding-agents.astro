---
import Layout from "../layouts/Layout.astro";
import { Footer } from "@/components/sections/footer";
import { Navbar } from "@/components/sections/navbar";
import { Terminal } from "@/components/ui/terminal";
import { SITE_CONFIG } from "@/site-config";
import { sitePath } from "@/lib/site-path";
import type { TechArticle, WithContext } from "schema-dts";

export const prerender = true;

const title =
  "Control Claude Code and Codex from your phone while your MacBook is closed";
const description =
  "Use OpenLid to keep Claude Code Remote Control, Codex remote connections, builds, tests, and local agent sessions running on your laptop while you steer them from your phone.";

const canonicalUrl = Astro.site
  ? new URL(sitePath("/coding-agents"), Astro.site).toString()
  : undefined;

const jsonLd: WithContext<TechArticle> = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: title,
  name: title,
  description,
  ...(canonicalUrl && { url: canonicalUrl, mainEntityOfPage: canonicalUrl }),
  about: [
    { "@type": "Thing", name: "Claude Code" },
    { "@type": "Thing", name: "Codex" },
    { "@type": "Thing", name: "Remote development" },
    { "@type": "SoftwareApplication", name: SITE_CONFIG.name },
  ],
};

const remoteOptions = [
  {
    title: "Codex remote connections",
    body: "Set up Codex mobile from the Codex App, then use ChatGPT on iOS or Android to send prompts, approve actions, and inspect output from the connected host.",
  },
  {
    title: "Claude Code Remote Control",
    body: "Start Remote Control with `claude remote-control`, `claude --remote-control`, or `/remote-control`, then continue the local session from claude.ai/code or the Claude app.",
  },
  {
    title: "SSH, mosh, or Screen Sharing",
    body: "Keep a universal fallback for terminal panes, visual permission dialogs, private networks, and workflows outside the native mobile surfaces.",
  },
];

const agentFlows = [
  {
    title: "Claude Code",
    body: "Remote Control keeps execution on your machine while the phone or browser becomes a synced control surface. If the local process stops or the laptop sleeps, the session stops.",
  },
  {
    title: "Codex",
    body: "Codex remote connections use the connected host's files, tools, credentials, plugins, browser setup, and approvals. The phone sends instructions; the host does the work.",
  },
  {
    title: "Build and test loops",
    body: "The same closed-lid reliability helps long-running tests, local servers, package downloads, and terminal sessions continue while you step away.",
  },
];

const nativeControlOptions = [
  {
    eyebrow: "OpenAI Codex",
    title: "Connect the Codex App host to ChatGPT mobile.",
    body: "Codex remote connections let you control a trusted Mac or Windows host from ChatGPT mobile. The host provides the repository, shell, local tools, browser setup, Computer Use, plugins, MCP servers, sandbox, and approvals.",
    steps: [
      "Install and sign in to the latest Codex App on the Mac or Windows host.",
      "Open Codex on that host and choose Set up Codex mobile in the sidebar.",
      "Scan the QR code from ChatGPT mobile and finish the same account and workspace flow.",
      "Keep the host awake and online; remote access stops when the host is unavailable.",
    ],
    docsHref: "https://developers.openai.com/codex/remote-connections",
  },
  {
    eyebrow: "Anthropic Claude Code",
    title: "Expose one local Claude Code session to web or mobile.",
    body: "Claude Code Remote Control keeps the session running locally while claude.ai/code or the Claude app acts as the remote window. Your filesystem, MCP servers, tools, and project configuration stay on the laptop.",
    steps: [
      "Use Claude Code v2.1.51 or later and sign in with a claude.ai subscription.",
      "Run `claude remote-control`, `claude --remote-control`, or `/remote-control` inside an active session.",
      "Open the session URL, scan the QR code, or find the named session in the Claude app.",
      "Keep the local `claude` process, network connection, and laptop awake.",
    ],
    docsHref: "https://docs.anthropic.com/en/docs/claude-code/remote-control",
  },
];

const sourceLinks = [
  {
    title: "Codex remote connections",
    href: "https://developers.openai.com/codex/remote-connections",
    body: "OpenAI's setup path for controlling a Codex App host from ChatGPT mobile and managing connected hosts.",
  },
  {
    title: "Claude Code Remote Control",
    href: "https://docs.anthropic.com/en/docs/claude-code/remote-control",
    body: "Anthropic's setup path for continuing local Claude Code sessions from claude.ai/code or the Claude mobile app.",
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <div class="min-h-screen bg-ploy-background-primary text-ploy-text-primary">
    <Navbar client:load />

    <main>
      <section class="relative overflow-hidden">
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-x-0 top-[-12%] mx-auto h-[560px] max-w-4xl rounded-full bg-ploy-accent-primary/[0.07] blur-[120px]"
        >
        </div>

        <div class="relative mx-auto grid max-w-6xl gap-12 px-5 pb-20 pt-20 sm:px-8 lg:grid-cols-[0.95fr_1.05fr] lg:pt-28">
          <div>
            <p class="font-eyebrow text-xs uppercase tracking-[0.18em] text-ploy-accent-primary">
              Remote coding agents
            </p>
            <h1 class="font-heading typography-heading mt-4 text-balance text-[2.6rem] leading-[1.02] tracking-[-0.03em] text-ploy-text-primary sm:text-6xl">
              Run the agent on your laptop. Steer it from your phone.
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-relaxed text-ploy-text-secondary sm:text-lg">
              OpenLid keeps your Mac awake with the lid closed, so Claude Code,
              Codex, local servers, builds, and test loops keep moving while you
              walk away. Native Codex and Claude Code remote-control surfaces
              can steer the session from your phone; OpenLid keeps the laptop
              side alive.
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href="https://github.com/openlid/openlid/releases/latest"
                target="_blank"
                rel="noreferrer"
                class="inline-flex h-12 items-center justify-center rounded-md bg-ploy-neutral-inverse px-6 font-button text-base font-medium text-ploy-text-on-accent-primary transition-colors hover:bg-ploy-neutral-inverse/90"
              >
                Download OpenLid
              </a>
              <a
                href={sitePath("/")}
                class="inline-flex h-12 items-center justify-center rounded-md border border-ploy-button-secondary-border bg-white/[0.02] px-6 font-button text-base font-medium text-ploy-text-primary transition-colors hover:bg-white/[0.06]"
              >
                Back to overview
              </a>
            </div>
          </div>

          <div class="grid content-start gap-4">
            <Terminal
              title="macbook — coding harness"
              lines={[
                { kind: "prompt", text: "openlid on" },
                { kind: "ok", text: "Active — preventing sleep now" },
                { kind: "comment", text: "" },
                { kind: "prompt", text: "claude --remote-control \"OpenLid\"" },
                { kind: "out", text: "Session URL + QR code ready" },
                { kind: "comment", text: "  // or: Codex App → Set up Codex mobile" },
              ]}
            />
            <Terminal
              title="phone — native control"
              lines={[
                { kind: "prompt", text: "open Claude app → Code" },
                { kind: "prompt", text: "open ChatGPT app → Codex" },
                { kind: "ok", text: "Approve, redirect, and review from phone" },
              ]}
            />
          </div>
        </div>
      </section>

      <section class="border-t border-white/[0.06]">
        <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
          <div class="max-w-2xl">
            <p class="font-eyebrow text-xs uppercase tracking-[0.18em] text-ploy-accent-primary">
              The handoff
            </p>
            <h2 class="font-heading typography-heading mt-3 text-balance text-3xl tracking-[-0.02em] text-ploy-text-primary sm:text-4xl">
              One Mac does the work. Your phone stays in control.
            </h2>
          </div>

          <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-white/[0.07] bg-white/[0.06] lg:grid-cols-4">
            {
              [
                ["1", "Arm OpenLid", "Keep macOS awake before you close the lid."],
                ["2", "Enable remote control", "Use Codex mobile setup or Claude Code Remote Control before you leave."],
                ["3", "Close the lid", "The internal display can turn off while the local process keeps working."],
                ["4", "Steer from phone", "Approve actions, answer questions, review output, or redirect the task."],
              ].map(([step, heading, body]) => (
                <div class="bg-ploy-background-primary p-6">
                  <span class="font-mono text-sm text-ploy-accent-primary">
                    {step}
                  </span>
                  <h3 class="mt-4 text-base font-semibold text-ploy-text-primary">
                    {heading}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-ploy-text-secondary">
                    {body}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="border-t border-white/[0.06]">
        <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
          <div class="max-w-3xl">
            <p class="font-eyebrow text-xs uppercase tracking-[0.18em] text-ploy-accent-primary">
              Native mobile control
            </p>
            <h2 class="font-heading typography-heading mt-3 text-balance text-3xl tracking-[-0.02em] text-ploy-text-primary sm:text-4xl">
              You do not have to teach everyone SSH first.
            </h2>
            <p class="mt-4 text-base leading-relaxed text-ploy-text-secondary">
              Codex and Claude Code now have official ways to drive local work
              from web and mobile surfaces. That makes the OpenLid pitch easier:
              start the agent on the laptop that already has the repo, then use
              the product's own phone interface to keep supervising it.
            </p>
          </div>

          <div class="mt-12 grid gap-5 lg:grid-cols-2">
            {
              nativeControlOptions.map((option) => (
                <article class="rounded-2xl border border-white/[0.07] bg-white/[0.015] p-6 sm:p-7">
                  <p class="font-eyebrow text-xs uppercase tracking-[0.18em] text-ploy-accent-primary">
                    {option.eyebrow}
                  </p>
                  <h3 class="mt-3 text-xl font-semibold tracking-[-0.01em] text-ploy-text-primary">
                    {option.title}
                  </h3>
                  <p class="mt-3 text-sm leading-relaxed text-ploy-text-secondary">
                    {option.body}
                  </p>
                  <ol class="mt-6 space-y-3">
                    {option.steps.map((step, index) => (
                      <li class="flex gap-3 text-sm leading-relaxed text-ploy-text-secondary">
                        <span class="mt-0.5 font-mono text-xs text-ploy-accent-primary">
                          {String(index + 1).padStart(2, "0")}
                        </span>
                        <span>{step}</span>
                      </li>
                    ))}
                  </ol>
                  <a
                    href={option.docsHref}
                    target="_blank"
                    rel="noreferrer"
                    class="mt-6 inline-flex text-sm font-medium text-ploy-text-primary transition-colors hover:text-ploy-accent-primary"
                  >
                    Read the official setup docs
                  </a>
                </article>
              ))
            }
          </div>

          <div class="mt-8 rounded-2xl border border-ploy-accent-primary/20 bg-ploy-accent-primary/[0.04] p-6">
            <h3 class="text-base font-semibold text-ploy-text-primary">
              Where OpenLid fits
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ploy-text-secondary">
              Remote-control products can route prompts and approvals, but the
              connected local host still has to stay awake, online, and running
              the agent process. OpenLid targets that physical laptop failure
              mode: the moment the lid closes and macOS would normally sleep.
            </p>
          </div>
        </div>
      </section>

      <section class="border-t border-white/[0.06]">
        <div class="mx-auto grid max-w-6xl gap-12 px-5 py-20 sm:px-8 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <p class="font-eyebrow text-xs uppercase tracking-[0.18em] text-ploy-accent-primary">
              Agent workflows
            </p>
            <h2 class="font-heading typography-heading mt-3 text-balance text-3xl tracking-[-0.02em] text-ploy-text-primary sm:text-4xl">
              Built for long-running local work.
            </h2>
            <p class="mt-4 text-base leading-relaxed text-ploy-text-secondary">
              OpenLid does not replace Claude Code, Codex, ChatGPT mobile,
              Claude mobile, SSH, or your remote terminal. It makes the laptop
              reliable enough to host them after the lid closes.
            </p>
          </div>

          <div class="grid gap-4">
            {
              agentFlows.map((flow) => (
                <div class="rounded-2xl border border-white/[0.07] bg-white/[0.015] p-6">
                  <h3 class="text-lg font-semibold text-ploy-text-primary">
                    {flow.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-ploy-text-secondary">
                    {flow.body}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="border-t border-white/[0.06]">
        <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
          <div class="max-w-2xl">
            <p class="font-eyebrow text-xs uppercase tracking-[0.18em] text-ploy-accent-primary">
              Remote access
            </p>
            <h2 class="font-heading typography-heading mt-3 text-balance text-3xl tracking-[-0.02em] text-ploy-text-primary sm:text-4xl">
              Use native remote control first. Keep a fallback.
            </h2>
            <p class="mt-4 text-base leading-relaxed text-ploy-text-secondary">
              OpenLid does not open ports, proxy traffic, or create a phone app.
              Use Codex and Claude Code's own remote-control flows when they fit
              your account and workflow. Keep SSH, mosh, or Screen Sharing for
              the cases where a terminal or visual desktop fallback is still the
              right tool.
            </p>
          </div>

          <div class="mt-12 grid gap-5 md:grid-cols-3">
            {
              remoteOptions.map((option) => (
                <div class="rounded-2xl border border-white/[0.07] bg-white/[0.015] p-6">
                  <h3 class="text-base font-semibold text-ploy-text-primary">
                    {option.title}
                  </h3>
                  <p class="mt-3 text-sm leading-relaxed text-ploy-text-secondary">
                    {option.body}
                  </p>
                </div>
              ))
            }
          </div>

          <div class="mt-8 rounded-2xl border border-ploy-accent-primary/20 bg-ploy-accent-primary/[0.04] p-6">
            <h3 class="text-base font-semibold text-ploy-text-primary">
              Security boundary
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ploy-text-secondary">
              Treat each remote-control surface as its own security decision.
              Native Codex and Claude Code flows use their own authenticated
              relays; SSH and Screen Sharing still need private networking,
              keys, device locks, and short-lived sessions. OpenLid keeps the
              laptop awake; it does not make remote access public by itself.
            </p>
          </div>

          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {
              sourceLinks.map((source) => (
                <a
                  href={source.href}
                  target="_blank"
                  rel="noreferrer"
                  class="rounded-2xl border border-white/[0.07] bg-white/[0.015] p-5 transition-colors hover:border-ploy-accent-primary/40"
                >
                  <p class="text-sm font-semibold text-ploy-text-primary">
                    {source.title}
                  </p>
                  <p class="mt-2 text-sm leading-relaxed text-ploy-text-secondary">
                    {source.body}
                  </p>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <section class="border-t border-white/[0.06]">
        <div class="mx-auto max-w-2xl px-5 py-24 text-center sm:px-8">
          <h2 class="font-heading typography-heading text-balance text-4xl tracking-[-0.03em] text-ploy-text-primary sm:text-5xl">
            Start the agent. Close the lid. Keep moving.
          </h2>
          <p class="mx-auto mt-5 max-w-lg text-base leading-relaxed text-ploy-text-secondary">
            OpenLid is the small piece that lets the rest of your mobile coding
            workflow stay alive on the machine that already has your repo,
            credentials, tools, and context.
          </p>
          <a
            href="https://github.com/openlid/openlid/releases/latest"
            target="_blank"
            rel="noreferrer"
            class="mt-8 inline-flex h-12 items-center justify-center rounded-md bg-ploy-neutral-inverse px-6 font-button text-base font-medium text-ploy-text-on-accent-primary transition-colors hover:bg-ploy-neutral-inverse/90"
          >
            Download OpenLid
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
