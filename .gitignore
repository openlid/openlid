/target
# Ignore everything in /dist EXCEPT the Homebrew cask source. Note this
# pattern lists contents of /dist rather than /dist itself, so the
# negation below can re-include the homebrew/ subtree.
/dist/*
!/dist/homebrew/
**/*.rs.bk
.DS_Store

# Build artifacts
*.app/
*.dmg
*.zip

# IDE
.vscode/
.idea/
*.iml

# Signing / notarization credentials — never commit
.env
.env.local
*.p12
*.cer
*.mobileprovision
notarization-credentials*
AuthKey_*.p8
